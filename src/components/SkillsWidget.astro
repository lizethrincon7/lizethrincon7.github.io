---
interface Skill {
  name: string;
  level: 'Basico' | 'Intermedio' | 'Avanzado';
  icon: string;
}

const skills: Skill[] = [
  { name: 'Excel', level: 'Avanzado', icon: '📗' },
  { name: 'Python', level: 'Basico', icon: '🐍' },
  { name: 'Power BI', level: 'Intermedio', icon: '📊' },
  { name: 'Power Platform', level: 'Intermedio', icon: '👩‍💻' },
];

const lightskills: Skill[] = [
  { name: 'Mejora Continua',  icon: '🕵️‍♀️' },
  { name: 'Autodidacta',  icon: '📝' },
  { name: 'Trabajo en equipo',  icon: '🤝' },
  { name: 'Adaptabilidad', icon: '⚙️' },
];

const levelColors = {
  Basico: 'bg-blue-100 text-blue-700',
  Avanzado: 'bg-green-100 text-green-700',
  Intermedio: 'bg-yellow-100 text-yellow-700'
};
---

<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl">
  <h3 class="text-2xl font-semibold mb-4">Habilidades técnicas</h3>
  <div class="space-y-4">
    {skills.map((skill) => (
      <div class="flex items-center justify-between p-3 hover:bg-apple-gray-50 rounded-xl transition-colors">
        <div class="flex items-center gap-3">
          <span class="text-xl">{skill.icon}</span>
          <span class="font-medium text-apple-gray-500">{skill.name}</span>
        </div>
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${levelColors[skill.level]}`}>
          {skill.level}
        </span>
      </div>
    ))}
  </div>
  <div></div>
   <h3 class="text-2xl font-semibold mb-4">Habilidades blandas</h3>
  <div class="space-y-4">
    {lightskills.map((skill) => (
      <div class="flex items-center justify-between p-3 hover:bg-apple-gray-50 rounded-xl transition-colors">
        <div class="flex items-center gap-3">
          <span class="text-xl">{skill.icon}</span>
          <span class="font-medium text-apple-gray-500">{skill.name}</span>
        </div>
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${levelColors[skill.level]}`}>
          {skill.level}
        </span>
      </div>
    ))}
  </div>
</div>